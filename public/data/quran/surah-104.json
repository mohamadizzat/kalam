[
  {
    "key": "104:1",
    "number": 1,
    "arabic": " وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ",
    "portuguese": "Ai de todo difamador, caluniador."
  },
  {
    "key": "104:2",
    "number": 2,
    "arabic": "ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ",
    "portuguese": "Que junta riquezas e, com deleite, as conta,"
  },
  {
    "key": "104:3",
    "number": 3,
    "arabic": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ",
    "portuguese": "Supõe que suas riquezas o tornarão eterno."
  },
  {
    "key": "104:4",
    "number": 4,
    "arabic": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ",
    "portuguese": "Em absoluto, não o tornarão! Em verdade, ele será deitado fora, em al-Hutama."
  },
  {
    "key": "104:5",
    "number": 5,
    "arabic": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ",
    "portuguese": "E o que te faz inteirar-te do que é al-Hutamah?"
  },
  {
    "key": "104:6",
    "number": 6,
    "arabic": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ",
    "portuguese": "É o fogo aceso, de Allah,"
  },
  {
    "key": "104:7",
    "number": 7,
    "arabic": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ",
    "portuguese": "O qual sobe até os corações."
  },
  {
    "key": "104:8",
    "number": 8,
    "arabic": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ",
    "portuguese": "Por certo, será cerrado sobre eles,"
  },
  {
    "key": "104:9",
    "number": 9,
    "arabic": "فِى عَمَدٍ مُّمَدَّدَةٍۭ",
    "portuguese": "Em colunas extensas."
  }
]