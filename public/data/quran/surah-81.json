[
  {
    "key": "81:1",
    "number": 1,
    "arabic": " إِذَا ٱلشَّمْسُ كُوِّرَتْ",
    "portuguese": "Quando o sol for enrolado,"
  },
  {
    "key": "81:2",
    "number": 2,
    "arabic": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ",
    "portuguese": "E quando as estrelas se tombarem,"
  },
  {
    "key": "81:3",
    "number": 3,
    "arabic": "وَإِذَا ٱلْجِبَالُ سُيِّرَتْ",
    "portuguese": "E quando as montanhas forem movidas,"
  },
  {
    "key": "81:4",
    "number": 4,
    "arabic": "وَإِذَا ٱلْعِشَارُ عُطِّلَتْ",
    "portuguese": "E quando os camelos fêmeas, prestes a dar à luz, forem descurados,"
  },
  {
    "key": "81:5",
    "number": 5,
    "arabic": "وَإِذَا ٱلْوُحُوشُ حُشِرَتْ",
    "portuguese": "E quando as feras forem reunidas,"
  },
  {
    "key": "81:6",
    "number": 6,
    "arabic": "وَإِذَا ٱلْبِحَارُ سُجِّرَتْ",
    "portuguese": "E quando os mares forem abrasados,"
  },
  {
    "key": "81:7",
    "number": 7,
    "arabic": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ",
    "portuguese": "E quando as almas forem parelhadas."
  },
  {
    "key": "81:8",
    "number": 8,
    "arabic": "وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ",
    "portuguese": "E quando a filha, enterrada viva, for interrogada,"
  },
  {
    "key": "81:9",
    "number": 9,
    "arabic": "بِأَىِّ ذَنۢبٍ قُتِلَتْ",
    "portuguese": "Por que delito fora morta."
  },
  {
    "key": "81:10",
    "number": 10,
    "arabic": "وَإِذَا ٱلصُّحُفُ نُشِرَتْ",
    "portuguese": "E quando as páginas forem desenroladas,"
  },
  {
    "key": "81:11",
    "number": 11,
    "arabic": "وَإِذَا ٱلسَّمَآءُ كُشِطَتْ",
    "portuguese": "E quando o céu for esfolado,"
  },
  {
    "key": "81:12",
    "number": 12,
    "arabic": "وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ",
    "portuguese": "E quando o Inferno for atiçado,"
  },
  {
    "key": "81:13",
    "number": 13,
    "arabic": "وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ",
    "portuguese": "E quando o Paraíso for aproximado,"
  },
  {
    "key": "81:14",
    "number": 14,
    "arabic": "عَلِمَتْ نَفْسٌ مَّآ أَحْضَرَتْ",
    "portuguese": "Toda alma saberá o que realizou."
  },
  {
    "key": "81:15",
    "number": 15,
    "arabic": "فَلَآ أُقْسِمُ بِٱلْخُنَّسِ",
    "portuguese": "Então, juro pelos planetas absconsos,"
  },
  {
    "key": "81:16",
    "number": 16,
    "arabic": "ٱلْجَوَارِ ٱلْكُنَّسِ",
    "portuguese": "Que correm e se escondem!"
  },
  {
    "key": "81:17",
    "number": 17,
    "arabic": "وَٱلَّيْلِ إِذَا عَسْعَسَ",
    "portuguese": "E pela noite, quando se vai!"
  },
  {
    "key": "81:18",
    "number": 18,
    "arabic": "وَٱلصُّبْحِ إِذَا تَنَفَّسَ",
    "portuguese": "E pela manhã, quando respira!"
  },
  {
    "key": "81:19",
    "number": 19,
    "arabic": "إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ",
    "portuguese": "Por certo, ele é o dito de um nobre Mensageiro,"
  },
  {
    "key": "81:20",
    "number": 20,
    "arabic": "ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍ",
    "portuguese": "De grande força, prestigiado junto do Possuidor do Trono,"
  },
  {
    "key": "81:21",
    "number": 21,
    "arabic": "مُّطَاعٍ ثَمَّ أَمِينٍ",
    "portuguese": "A quem se obedece, lá; leal."
  },
  {
    "key": "81:22",
    "number": 22,
    "arabic": "وَمَا صَاحِبُكُم بِمَجْنُونٍ",
    "portuguese": "E vosso companheiro não é louco;"
  },
  {
    "key": "81:23",
    "number": 23,
    "arabic": "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ",
    "portuguese": "E, com efeito, ele o viu, no evidente horizonte."
  },
  {
    "key": "81:24",
    "number": 24,
    "arabic": "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍ",
    "portuguese": "E ele não é avaro quanto ao Invisível."
  },
  {
    "key": "81:25",
    "number": 25,
    "arabic": "وَمَا هُوَ بِقَوْلِ شَيْطَـٰنٍ رَّجِيمٍ",
    "portuguese": "E ele não é um dito de demônio maldito."
  },
  {
    "key": "81:26",
    "number": 26,
    "arabic": "فَأَيْنَ تَذْهَبُونَ",
    "portuguese": "Então, aonde ides?"
  },
  {
    "key": "81:27",
    "number": 27,
    "arabic": "إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَـٰلَمِينَ",
    "portuguese": "Ele não é senão lembrança para os mundos,"
  },
  {
    "key": "81:28",
    "number": 28,
    "arabic": "لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ",
    "portuguese": "Para quem, dentre vós, queira ser reto"
  },
  {
    "key": "81:29",
    "number": 29,
    "arabic": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَـٰلَمِينَ",
    "portuguese": "Mas não o querereis, a não ser que Allah, O Senhor dos mundos, o queira."
  }
]