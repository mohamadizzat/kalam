[
  {
    "key": "93:1",
    "number": 1,
    "arabic": " وَٱلضُّحَىٰ",
    "portuguese": "Pela plena luz matinal!"
  },
  {
    "key": "93:2",
    "number": 2,
    "arabic": "وَٱلَّيْلِ إِذَا سَجَىٰ",
    "portuguese": "E pela noite, quando serena!"
  },
  {
    "key": "93:3",
    "number": 3,
    "arabic": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
    "portuguese": "Teu Senhor não te abandonou nem te detestou."
  },
  {
    "key": "93:4",
    "number": 4,
    "arabic": "وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ",
    "portuguese": "E, em verdade, a Derradeira Vida te é melhor que a primeira."
  },
  {
    "key": "93:5",
    "number": 5,
    "arabic": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
    "portuguese": "E, em verdade, teu Senhor dar-te-á graças, e disso te agradarás."
  },
  {
    "key": "93:6",
    "number": 6,
    "arabic": "أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ",
    "portuguese": "Não te encontrou órfão e te abrigou?"
  },
  {
    "key": "93:7",
    "number": 7,
    "arabic": "وَوَجَدَكَ ضَآلًّا فَهَدَىٰ",
    "portuguese": "E não te encontrou descaminhado e te guiou?"
  },
  {
    "key": "93:8",
    "number": 8,
    "arabic": "وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ",
    "portuguese": "E não te encontrou infortunado e te enriqueceu?"
  },
  {
    "key": "93:9",
    "number": 9,
    "arabic": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
    "portuguese": "Então, quanto ao órfão, não o oprimas"
  },
  {
    "key": "93:10",
    "number": 10,
    "arabic": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
    "portuguese": "E, quanto ao mendigo, não o maltrates."
  },
  {
    "key": "93:11",
    "number": 11,
    "arabic": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
    "portuguese": "E, quanto à graça de teu Senhor, proclama-a."
  }
]