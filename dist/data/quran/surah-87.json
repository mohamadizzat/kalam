[
  {
    "key": "87:1",
    "number": 1,
    "arabic": " سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
    "portuguese": "Glorifica o nome de teu Senhor, O Altíssimo,"
  },
  {
    "key": "87:2",
    "number": 2,
    "arabic": "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
    "portuguese": "Que tudo criou e formou,"
  },
  {
    "key": "87:3",
    "number": 3,
    "arabic": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
    "portuguese": "E Que tudo determinou e guiou,"
  },
  {
    "key": "87:4",
    "number": 4,
    "arabic": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
    "portuguese": "E Que fez sair a pastagem,"
  },
  {
    "key": "87:5",
    "number": 5,
    "arabic": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
    "portuguese": "E fê-la feno enegrecido."
  },
  {
    "key": "87:6",
    "number": 6,
    "arabic": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
    "portuguese": "Nós far-te-emos ler, e de nada te esquecerás,"
  },
  {
    "key": "87:7",
    "number": 7,
    "arabic": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
    "portuguese": "Exceto do que Allah quiser. - Por certo, Ele sabe o declarado e o que se oculta -"
  },
  {
    "key": "87:8",
    "number": 8,
    "arabic": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
    "portuguese": "E facilitar-te-emos o acesso ao caminho fácil,"
  },
  {
    "key": "87:9",
    "number": 9,
    "arabic": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
    "portuguese": "Então, lembra-lhes, se a lembrança os beneficiar."
  },
  {
    "key": "87:10",
    "number": 10,
    "arabic": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
    "portuguese": "Lembrar-se-á quem receia a Allah,"
  },
  {
    "key": "87:11",
    "number": 11,
    "arabic": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
    "portuguese": "E evitá-lo-á o mais infeliz,"
  },
  {
    "key": "87:12",
    "number": 12,
    "arabic": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
    "portuguese": "Que se queimará no Fogo maior,"
  },
  {
    "key": "87:13",
    "number": 13,
    "arabic": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
    "portuguese": "Em seguida, nele, não morrerá nem viverá."
  },
  {
    "key": "87:14",
    "number": 14,
    "arabic": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
    "portuguese": "Com efeito, bem aventurado é quem se dignifica"
  },
  {
    "key": "87:15",
    "number": 15,
    "arabic": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
    "portuguese": "E se lembra do nome de seu Senhor e ora."
  },
  {
    "key": "87:16",
    "number": 16,
    "arabic": "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
    "portuguese": "Mas vós dais preferência à vida terrena,"
  },
  {
    "key": "87:17",
    "number": 17,
    "arabic": "وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ",
    "portuguese": "Enquanto a Derradeira Vida é melhor e mais permanente."
  },
  {
    "key": "87:18",
    "number": 18,
    "arabic": "إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ",
    "portuguese": "Por certo, isto está nas primeiras Páginas,"
  },
  {
    "key": "87:19",
    "number": 19,
    "arabic": "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ",
    "portuguese": "Nas Páginas de Abraão e de Moisés"
  }
]