[
  {
    "key": "86:1",
    "number": 1,
    "arabic": " وَٱلسَّمَآءِ وَٱلطَّارِقِ",
    "portuguese": "Pelo céu e pelo astro noturno,"
  },
  {
    "key": "86:2",
    "number": 2,
    "arabic": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
    "portuguese": "- E o que te faz inteirar-te do que é o astro noturno?"
  },
  {
    "key": "86:3",
    "number": 3,
    "arabic": "ٱلنَّجْمُ ٱلثَّاقِبُ",
    "portuguese": "É a estrela fulgurante. -"
  },
  {
    "key": "86:4",
    "number": 4,
    "arabic": "إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ",
    "portuguese": "Por certo, sobre cada alma há um anjo custódio!"
  },
  {
    "key": "86:5",
    "number": 5,
    "arabic": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ",
    "portuguese": "Então, que o ser humano olhe aquilo de que foi criado."
  },
  {
    "key": "86:6",
    "number": 6,
    "arabic": "خُلِقَ مِن مَّآءٍ دَافِقٍ",
    "portuguese": "Foi criado de água emitida,"
  },
  {
    "key": "86:7",
    "number": 7,
    "arabic": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
    "portuguese": "Que sai de entre a espinha dorsal e os ossos do peito."
  },
  {
    "key": "86:8",
    "number": 8,
    "arabic": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ",
    "portuguese": "Por certo, Ele, sobre seu retorno, é Poderoso."
  },
  {
    "key": "86:9",
    "number": 9,
    "arabic": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
    "portuguese": "Um dia, quando forem postos à prova os segredos,"
  },
  {
    "key": "86:10",
    "number": 10,
    "arabic": "فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ",
    "portuguese": "Então, ele não terá nem força nem socorredor."
  },
  {
    "key": "86:11",
    "number": 11,
    "arabic": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
    "portuguese": "Pelo céu do retorno da chuva!"
  },
  {
    "key": "86:12",
    "number": 12,
    "arabic": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
    "portuguese": "E pela terra de gretas!"
  },
  {
    "key": "86:13",
    "number": 13,
    "arabic": "إِنَّهُۥ لَقَوْلٌ فَصْلٌ",
    "portuguese": "Por certo, ele é um dito decisivo,"
  },
  {
    "key": "86:14",
    "number": 14,
    "arabic": "وَمَا هُوَ بِٱلْهَزْلِ",
    "portuguese": "E não um gracejo!"
  },
  {
    "key": "86:15",
    "number": 15,
    "arabic": "إِنَّهُمْ يَكِيدُونَ كَيْدًا",
    "portuguese": "Por certo, eles armam insídias,"
  },
  {
    "key": "86:16",
    "number": 16,
    "arabic": "وَأَكِيدُ كَيْدًا",
    "portuguese": "E, também, armo insídias."
  },
  {
    "key": "86:17",
    "number": 17,
    "arabic": "فَمَهِّلِ ٱلْكَـٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
    "portuguese": "Então, dá prazo aos renegadores da Fé: dá-lhes um pouco de prazo."
  }
]