  },
  {
    "key": "102:4",
    "number": 4,
    "arabic": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
    "portuguese": "Mais uma vez, em absoluto, não vos ostenteis! Vós logo sabereis!"
  },
  {
    "key": "102:5",
