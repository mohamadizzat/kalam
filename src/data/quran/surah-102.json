[
  {
    "key": "102:1",
    "number": 1,
    "arabic": " أَلْهَىٰكُمُ ٱلتَّكَاثُرُ",
    "portuguese": "A ostentação entretém-vos,"
  },
  {
    "key": "102:2",
    "number": 2,
    "arabic": "حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ",
    "portuguese": "Até visitardes os sepulcros."
  },
  {
    "key": "102:3",
    "number": 3,
    "arabic": "كَلَّا سَوْفَ تَعْلَمُونَ",
