  },
  {
    "key": "102:8",
    "number": 8,
    "arabic": "ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ",
    "portuguese": "Depois, sereis, em verdade, nesse dia, interrogados das delícias da vida."
