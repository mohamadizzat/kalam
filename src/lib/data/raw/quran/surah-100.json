[
  {
    "key": "100:1",
    "number": 1,
    "arabic": " وَٱلْعَـٰدِيَـٰتِ ضَبْحًا",
    "portuguese": "Pelos corcéis arquejantes,"
  },
  {
    "key": "100:2",
    "number": 2,
    "arabic": "فَٱلْمُورِيَـٰتِ قَدْحًا",
    "portuguese": "E chispeantes, com seus cascos,"
  },
  {
    "key": "100:3",
    "number": 3,
    "arabic": "فَٱلْمُغِيرَٰتِ صُبْحًا",
    "portuguese": "E atacantes, pela manhã,"
  },
  {
    "key": "100:4",
    "number": 4,
    "arabic": "فَأَثَرْنَ بِهِۦ نَقْعًا",
    "portuguese": "Então, levantam, com isso, nuvens de poeira"
  },
  {
    "key": "100:5",
    "number": 5,
    "arabic": "فَوَسَطْنَ بِهِۦ جَمْعًا",
    "portuguese": "E permeiam, com isso, uma inimiga multidão."
  },
  {
    "key": "100:6",
    "number": 6,
    "arabic": "إِنَّ ٱلْإِنسَـٰنَ لِرَبِّهِۦ لَكَنُودٌ",
    "portuguese": "Por certo, o ser humano é ingrato a seu Senhor;"
  },
  {
    "key": "100:7",
    "number": 7,
    "arabic": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ",
    "portuguese": "E, por certo, ele é testemunha disso;"
  },
  {
    "key": "100:8",
    "number": 8,
    "arabic": "وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ",
    "portuguese": "E, por certo, ele é veemente no amor à riqueza."
  },
  {
    "key": "100:9",
    "number": 9,
    "arabic": "۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ",
    "portuguese": "Então, não sabe ele que será recompensado, quando for revolvido o que há nos sepulcros,"
  },
  {
    "key": "100:10",
    "number": 10,
    "arabic": "وَحُصِّلَ مَا فِى ٱلصُّدُورِ",
    "portuguese": "E for recolhido o que há nos peito?"
  },
  {
    "key": "100:11",
    "number": 11,
    "arabic": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌۢ",
    "portuguese": "Por certo, nesse dia, o seu Senhor deles será Conhecedor."
  }
]