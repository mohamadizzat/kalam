[
  {
    "key": "88:1",
    "number": 1,
    "arabic": " هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَـٰشِيَةِ",
    "portuguese": "Chegou-te o relato da Envolvente?"
  },
  {
    "key": "88:2",
    "number": 2,
    "arabic": "وُجُوهٌ يَوْمَئِذٍ خَـٰشِعَةٌ",
    "portuguese": "Nesse dia, haverá faces humilhadas,"
  },
  {
    "key": "88:3",
    "number": 3,
    "arabic": "عَامِلَةٌ نَّاصِبَةٌ",
    "portuguese": "Preocupadas, fatigadas."
  },
  {
    "key": "88:4",
    "number": 4,
    "arabic": "تَصْلَىٰ نَارًا حَامِيَةً",
    "portuguese": "Queimar-se-ão em um Fogo incandescente."
  },
  {
    "key": "88:5",
    "number": 5,
    "arabic": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ",
    "portuguese": "Dar-se-lhes-á de beber de escaldante fonte."
  },
  {
    "key": "88:6",
    "number": 6,
    "arabic": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ",
    "portuguese": "Para eles, não haverá alimento, senão o de uma árvore seca esinhosa,"
  },
  {
    "key": "88:7",
    "number": 7,
    "arabic": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ",
    "portuguese": "Que não engorda e de nada vale contra a fome."
  },
  {
    "key": "88:8",
    "number": 8,
    "arabic": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ",
    "portuguese": "Nesse dia, haverá faces cheias de graça,"
  },
  {
    "key": "88:9",
    "number": 9,
    "arabic": "لِّسَعْيِهَا رَاضِيَةٌ",
    "portuguese": "Agradadas de seu esforço."
  },
  {
    "key": "88:10",
    "number": 10,
    "arabic": "فِى جَنَّةٍ عَالِيَةٍ",
    "portuguese": "Estarão em um alto Jardim;"
  },
  {
    "key": "88:11",
    "number": 11,
    "arabic": "لَّا تَسْمَعُ فِيهَا لَـٰغِيَةً",
    "portuguese": "Nele, tu não ouvirás frivolidade alguma."
  },
  {
    "key": "88:12",
    "number": 12,
    "arabic": "فِيهَا عَيْنٌ جَارِيَةٌ",
    "portuguese": "Nele, haverá uma fonte corrente;"
  },
  {
    "key": "88:13",
    "number": 13,
    "arabic": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ",
    "portuguese": "Nele, haverá leitos elevados,"
  },
  {
    "key": "88:14",
    "number": 14,
    "arabic": "وَأَكْوَابٌ مَّوْضُوعَةٌ",
    "portuguese": "E copos dispostos,"
  },
  {
    "key": "88:15",
    "number": 15,
    "arabic": "وَنَمَارِقُ مَصْفُوفَةٌ",
    "portuguese": "E almofadas enfileiradas"
  },
  {
    "key": "88:16",
    "number": 16,
    "arabic": "وَزَرَابِىُّ مَبْثُوثَةٌ",
    "portuguese": "E tapetes espalhados."
  },
  {
    "key": "88:17",
    "number": 17,
    "arabic": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
    "portuguese": "E não olham eles aos camelos, como foram criados?"
  },
  {
    "key": "88:18",
    "number": 18,
    "arabic": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
    "portuguese": "E ao céu, como foi elevado?"
  },
  {
    "key": "88:19",
    "number": 19,
    "arabic": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
    "portuguese": "E às montanhas, como foram armadas?"
  },
  {
    "key": "88:20",
    "number": 20,
    "arabic": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
    "portuguese": "E à terra, como foi distendida?"
  },
  {
    "key": "88:21",
    "number": 21,
    "arabic": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ",
    "portuguese": "Então, lembra-lhes o Alcorão. És, apenas lembrador."
  },
  {
    "key": "88:22",
    "number": 22,
    "arabic": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
    "portuguese": "Não és, sobre eles, dono absoluto."
  },
  {
    "key": "88:23",
    "number": 23,
    "arabic": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
    "portuguese": "Mas a quem volta as costas e renega a Fé,"
  },
  {
    "key": "88:24",
    "number": 24,
    "arabic": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
    "portuguese": "Allah castigá-lo-á com o castigo maior."
  },
  {
    "key": "88:25",
    "number": 25,
    "arabic": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
    "portuguese": "Por certo, a Nós será sua volta."
  },
  {
    "key": "88:26",
    "number": 26,
    "arabic": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
    "portuguese": "Em seguida, por certo, impender-Nos-á sua conta."
  }
]