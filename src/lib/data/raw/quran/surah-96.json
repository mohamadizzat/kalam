[
  {
    "key": "96:1",
    "number": 1,
    "arabic": " ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ",
    "portuguese": "Lê, em nome de teu Senhor, que criou,"
  },
  {
    "key": "96:2",
    "number": 2,
    "arabic": "خَلَقَ ٱلْإِنسَـٰنَ مِنْ عَلَقٍ",
    "portuguese": "Que criou o ser humano de uma aderência."
  },
  {
    "key": "96:3",
    "number": 3,
    "arabic": "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
    "portuguese": "Lê, e teu Senhor é O mais Generoso,"
  },
  {
    "key": "96:4",
    "number": 4,
    "arabic": "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
    "portuguese": "Que ensinou a escrever com o cálamo,"
  },
  {
    "key": "96:5",
    "number": 5,
    "arabic": "عَلَّمَ ٱلْإِنسَـٰنَ مَا لَمْ يَعْلَمْ",
    "portuguese": "Ensinou ao ser humano o que ele não sabia."
  },
  {
    "key": "96:6",
    "number": 6,
    "arabic": "كَلَّآ إِنَّ ٱلْإِنسَـٰنَ لَيَطْغَىٰٓ",
    "portuguese": "Ora, por certo, o ser humano a tudo transgride,"
  },
  {
    "key": "96:7",
    "number": 7,
    "arabic": "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
    "portuguese": "Desde que ele se vê prescindindo de ajuda."
  },
  {
    "key": "96:8",
    "number": 8,
    "arabic": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
    "portuguese": "Por certo, a teu Senhor será o retorno."
  },
  {
    "key": "96:9",
    "number": 9,
    "arabic": "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
    "portuguese": "Viste aquele que coíbe"
  },
  {
    "key": "96:10",
    "number": 10,
    "arabic": "عَبْدًا إِذَا صَلَّىٰٓ",
    "portuguese": "Um servo de orar, quando este ora?"
  },
  {
    "key": "96:11",
    "number": 11,
    "arabic": "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
    "portuguese": "Viste se ele está na Orientação,"
  },
  {
    "key": "96:12",
    "number": 12,
    "arabic": "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
    "portuguese": "Ou se ordena a piedade?"
  },
  {
    "key": "96:13",
    "number": 13,
    "arabic": "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
    "portuguese": "Viste se te desmente e te volta as costas?"
  },
  {
    "key": "96:14",
    "number": 14,
    "arabic": "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
    "portuguese": "Não sabe ele que Allah a tudo vê?"
  },
  {
    "key": "96:15",
    "number": 15,
    "arabic": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
    "portuguese": "Em absoluto, não o sabe! Em verdade, se ele não se detiver, arrastá-lo-emos pelo topete,"
  },
  {
    "key": "96:16",
    "number": 16,
    "arabic": "نَاصِيَةٍ كَـٰذِبَةٍ خَاطِئَةٍ",
    "portuguese": "Topete mentiroso, errado."
  },
  {
    "key": "96:17",
    "number": 17,
    "arabic": "فَلْيَدْعُ نَادِيَهُۥ",
    "portuguese": "Então, que convoque seus partidários."
  },
  {
    "key": "96:18",
    "number": 18,
    "arabic": "سَنَدْعُ ٱلزَّبَانِيَةَ",
    "portuguese": "Convocaremos os verdugos."
  },
  {
    "key": "96:19",
    "number": 19,
    "arabic": "كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩",
    "portuguese": "Em absoluto, não lhe obedeças; e prosterna-te e aproxima-te de Allah."
  }
]